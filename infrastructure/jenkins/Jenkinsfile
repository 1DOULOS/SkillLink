pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_IMAGE_PREFIX = 'skilllink'
        DOCKER_CREDENTIALS = credentials('docker-hub-credentials')
        KUBECONFIG = credentials('kubeconfig')
        POSTGRES_URL = credentials('skilllink-db-url')
        JWT_SECRET = credentials('skilllink-jwt-secret')
        SONAR_TOKEN = credentials('sonarqube-token')
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        // ── Stage 1: Checkout ──────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_COMMIT_SHORT = sh(
                        script: 'git rev-parse --short HEAD',
                        returnStdout: true
                    ).trim()
                    env.IMAGE_TAG = "${env.BUILD_NUMBER}-${env.GIT_COMMIT_SHORT}"
                }
                echo "Building commit: ${env.GIT_COMMIT_SHORT}, Tag: ${env.IMAGE_TAG}"
            }
        }

        // ── Stage 2: Install Dependencies ─────────────────────────────────────
        stage('Install Dependencies') {
            parallel {
                stage('Auth Service') {
                    steps {
                        dir('backend/auth-service') {
                            sh 'npm ci'
                        }
                    }
                }
                stage('User Service') {
                    steps {
                        dir('backend/user-service') {
                            sh 'npm ci'
                        }
                    }
                }
                stage('Job Service') {
                    steps {
                        dir('backend/job-service') {
                            sh 'npm ci'
                        }
                    }
                }
                stage('Matching Service') {
                    steps {
                        dir('backend/matching-service') {
                            sh 'pip install -r requirements.txt'
                        }
                    }
                }
                stage('Frontend') {
                    steps {
                        dir('frontend') {
                            sh 'npm ci'
                        }
                    }
                }
            }
        }

        // ── Stage 3: Lint & Static Analysis ───────────────────────────────────
        stage('Lint') {
            parallel {
                stage('Lint Auth Service') {
                    steps {
                        dir('backend/auth-service') {
                            sh 'npm run lint --if-present || true'
                        }
                    }
                }
                stage('Lint Job Service') {
                    steps {
                        dir('backend/job-service') {
                            sh 'npm run lint --if-present || true'
                        }
                    }
                }
                stage('Lint Frontend') {
                    steps {
                        dir('frontend') {
                            sh 'npm run lint --if-present || true'
                        }
                    }
                }
            }
        }

        // ── Stage 4: Unit & Integration Tests ─────────────────────────────────
        stage('Test') {
            parallel {
                stage('Test Auth Service') {
                    steps {
                        dir('backend/auth-service') {
                            sh 'npm run test:ci'
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: 'backend/auth-service/coverage/junit.xml'
                            publishHTML([
                                allowMissing: true,
                                alwaysLinkToLastBuild: true,
                                keepAll: true,
                                reportDir: 'backend/auth-service/coverage/lcov-report',
                                reportFiles: 'index.html',
                                reportName: 'Auth Service Coverage'
                            ])
                        }
                    }
                }
                stage('Test User Service') {
                    steps {
                        dir('backend/user-service') {
                            sh 'npm run test:ci'
                        }
                    }
                    post {
                        always {
                            publishHTML([
                                allowMissing: true,
                                alwaysLinkToLastBuild: true,
                                keepAll: true,
                                reportDir: 'backend/user-service/coverage/lcov-report',
                                reportFiles: 'index.html',
                                reportName: 'User Service Coverage'
                            ])
                        }
                    }
                }
                stage('Test Job Service') {
                    steps {
                        dir('backend/job-service') {
                            sh 'npm run test:ci'
                        }
                    }
                    post {
                        always {
                            publishHTML([
                                allowMissing: true,
                                alwaysLinkToLastBuild: true,
                                keepAll: true,
                                reportDir: 'backend/job-service/coverage/lcov-report',
                                reportFiles: 'index.html',
                                reportName: 'Job Service Coverage'
                            ])
                        }
                    }
                }
                stage('Test Matching Service') {
                    steps {
                        dir('backend/matching-service') {
                            sh 'pytest tests/ -v --cov=app --cov-report=term-missing --cov-report=xml:coverage.xml'
                        }
                    }
                    post {
                        always {
                            publishHTML([
                                allowMissing: true,
                                alwaysLinkToLastBuild: true,
                                keepAll: true,
                                reportDir: 'backend/matching-service/htmlcov',
                                reportFiles: 'index.html',
                                reportName: 'Matching Service Coverage'
                            ])
                        }
                    }
                }
                stage('Test Frontend') {
                    steps {
                        dir('frontend') {
                            sh 'npm test -- --reporter=junit --outputFile=test-results.xml || true'
                        }
                    }
                }
            }
        }

        // ── Stage 5: Build Docker Images ──────────────────────────────────────
        stage('Build Docker Images') {
            parallel {
                stage('Build Auth Image') {
                    steps {
                        dir('backend/auth-service') {
                            sh "docker build -t ${DOCKER_IMAGE_PREFIX}/auth-service:${IMAGE_TAG} -t ${DOCKER_IMAGE_PREFIX}/auth-service:latest ."
                        }
                    }
                }
                stage('Build User Image') {
                    steps {
                        dir('backend/user-service') {
                            sh "docker build -t ${DOCKER_IMAGE_PREFIX}/user-service:${IMAGE_TAG} -t ${DOCKER_IMAGE_PREFIX}/user-service:latest ."
                        }
                    }
                }
                stage('Build Job Image') {
                    steps {
                        dir('backend/job-service') {
                            sh "docker build -t ${DOCKER_IMAGE_PREFIX}/job-service:${IMAGE_TAG} -t ${DOCKER_IMAGE_PREFIX}/job-service:latest ."
                        }
                    }
                }
                stage('Build Matching Image') {
                    steps {
                        dir('backend/matching-service') {
                            sh "docker build -t ${DOCKER_IMAGE_PREFIX}/matching-service:${IMAGE_TAG} -t ${DOCKER_IMAGE_PREFIX}/matching-service:latest ."
                        }
                    }
                }
                stage('Build Frontend Image') {
                    steps {
                        dir('frontend') {
                            sh "docker build -t ${DOCKER_IMAGE_PREFIX}/frontend:${IMAGE_TAG} -t ${DOCKER_IMAGE_PREFIX}/frontend:latest ."
                        }
                    }
                }
            }
        }

        // ── Stage 6: Push to Registry ─────────────────────────────────────────
        stage('Push to Registry') {
            when {
                anyOf {
                    branch 'main'
                    branch 'develop'
                }
            }
            steps {
                sh "echo ${DOCKER_CREDENTIALS_PSW} | docker login -u ${DOCKER_CREDENTIALS_USR} --password-stdin"
                sh "docker push ${DOCKER_IMAGE_PREFIX}/auth-service:${IMAGE_TAG}"
                sh "docker push ${DOCKER_IMAGE_PREFIX}/auth-service:latest"
                sh "docker push ${DOCKER_IMAGE_PREFIX}/user-service:${IMAGE_TAG}"
                sh "docker push ${DOCKER_IMAGE_PREFIX}/user-service:latest"
                sh "docker push ${DOCKER_IMAGE_PREFIX}/job-service:${IMAGE_TAG}"
                sh "docker push ${DOCKER_IMAGE_PREFIX}/job-service:latest"
                sh "docker push ${DOCKER_IMAGE_PREFIX}/matching-service:${IMAGE_TAG}"
                sh "docker push ${DOCKER_IMAGE_PREFIX}/matching-service:latest"
                sh "docker push ${DOCKER_IMAGE_PREFIX}/frontend:${IMAGE_TAG}"
                sh "docker push ${DOCKER_IMAGE_PREFIX}/frontend:latest"
            }
        }

        // ── Stage 7: Deploy to Kubernetes ─────────────────────────────────────
        stage('Deploy to Kubernetes') {
            when {
                branch 'main'
            }
            steps {
                withKubeConfig([credentialsId: 'kubeconfig']) {
                    sh "kubectl apply -f infrastructure/kubernetes/namespace.yaml"
                    sh "kubectl apply -f infrastructure/kubernetes/configmap.yaml"
                    sh "kubectl apply -f infrastructure/kubernetes/secrets.yaml"
                    sh "kubectl apply -f infrastructure/kubernetes/postgres/"
                    sh "kubectl rollout status deployment/postgres -n skilllink --timeout=120s"
                    sh "kubectl apply -f infrastructure/kubernetes/auth-service/"
                    sh "kubectl apply -f infrastructure/kubernetes/user-service/"
                    sh "kubectl apply -f infrastructure/kubernetes/job-service/"
                    sh "kubectl apply -f infrastructure/kubernetes/matching-service/"
                    sh "kubectl apply -f infrastructure/kubernetes/frontend/"
                    sh "kubectl apply -f infrastructure/kubernetes/ingress.yaml"
                    // Update image tags
                    sh "kubectl set image deployment/auth-service auth-service=${DOCKER_IMAGE_PREFIX}/auth-service:${IMAGE_TAG} -n skilllink"
                    sh "kubectl set image deployment/user-service user-service=${DOCKER_IMAGE_PREFIX}/user-service:${IMAGE_TAG} -n skilllink"
                    sh "kubectl set image deployment/job-service job-service=${DOCKER_IMAGE_PREFIX}/job-service:${IMAGE_TAG} -n skilllink"
                    sh "kubectl set image deployment/matching-service matching-service=${DOCKER_IMAGE_PREFIX}/matching-service:${IMAGE_TAG} -n skilllink"
                    sh "kubectl set image deployment/frontend frontend=${DOCKER_IMAGE_PREFIX}/frontend:${IMAGE_TAG} -n skilllink"
                    // Wait for rollout
                    sh "kubectl rollout status deployment/auth-service -n skilllink --timeout=120s"
                    sh "kubectl rollout status deployment/job-service -n skilllink --timeout=120s"
                    sh "kubectl rollout status deployment/frontend -n skilllink --timeout=120s"
                }
            }
        }

        // ── Stage 8: Smoke Tests ───────────────────────────────────────────────
        stage('Smoke Tests') {
            when {
                branch 'main'
            }
            steps {
                sh '''
                    sleep 30
                    curl -f http://skilllink.example.com/health || exit 1
                    echo "Smoke test passed"
                '''
            }
        }

    }

    post {
        always {
            echo "Pipeline completed - Build #${BUILD_NUMBER}"
            cleanWs()
        }
        success {
            echo "Build ${IMAGE_TAG} deployed successfully!"
        }
        failure {
            echo "Build failed! Check logs above."
        }
    }
}
